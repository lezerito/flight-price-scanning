# Amadeus Self-Service API (https://developers.amadeus.com — free tier)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# "test" (default) or "production"
AMADEUS_ENV=test

# Travelpayouts Data API (https://www.travelpayouts.com — free)
TRAVELPAYOUTS_TOKEN=

# Gmail alerts (create an App Password: https://myaccount.google.com/apppasswords)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
MAIL_TO=

# Set to 1 to run the whole pipeline with generated data (no API calls)
MOCK_SCAN=0
